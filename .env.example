# Florida Chicken Coops — environment configuration
# Copy this file to ".env" and fill in real values. The .env file is gitignored.

# --- SMTP (the mailbox that SENDS the notification email) ---
# For Gmail: SMTP_USER is the full address, SMTP_PASS is a 16-char App Password
# (Google Account → Security → 2-Step Verification → App passwords), NOT the
# normal login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=cj@smashtoday.com
SMTP_PASS=ddyozbmfdqjncejr

# --- Recipients (who RECEIVES each submission) ---
CONTACT_RECEIVER=Mitchell@FlChickenCoops.com
# Optional extra recipients, comma-separated (no spaces around commas):
CONTACT_CC=

# --- reCAPTCHA (disabled for now) ---
# Leave ENABLE_RECAPTCHA=0 to skip verification. To enable later, set it to 1
# and provide both keys, then add the widget to templates/contact.html.
ENABLE_RECAPTCHA=0
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=
